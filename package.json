{
  "name": "philippines-payroll-data",
  "version": "2.0.0",
  "description": "Machine-readable, primary-sourced payroll reference for Southeast Asia (PH, SG, MY, TH, ID, VN) — income tax tables, mandatory contribution rates, labour law, minimum wages — every figure cited to the primary government document.",
  "type": "module",
  "exports": {
    ".": "./index.mjs",
    "./data/*": "./data/*",
    "./schema": "./schemas/payroll-data.schema.json"
  },
  "files": [
    "data/",
    "schemas/",
    "index.mjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CITATION.cff"
  ],
  "scripts": {
    "validate": "node tools/build-data.mjs --check"
  },
  "keywords": [
    "payroll",
    "southeast-asia",
    "asean",
    "philippines",
    "singapore",
    "malaysia",
    "thailand",
    "indonesia",
    "vietnam",
    "income-tax",
    "withholding-tax",
    "contributions",
    "sss",
    "philhealth",
    "pag-ibig",
    "bir",
    "cpf",
    "epf",
    "socso",
    "eis",
    "bpjs",
    "minimum-wage",
    "labour-law",
    "13th-month-pay",
    "de-minimis",
    "train-law",
    "tax",
    "open-data",
    "dataset",
    "json",
    "llms-txt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-payroll-data/philippines-payroll-data.git"
  },
  "homepage": "https://open-payroll-data.github.io/philippines-payroll-data/",
  "bugs": {
    "url": "https://github.com/open-payroll-data/philippines-payroll-data/issues"
  },
  "sideEffects": false
}
